{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opays.tech/schemas/opays.manifest.schema.json",
  "title": "Opays Integration Manifest",
  "description": "Contrat officiel d'intégration entre une application Opays et le moteur OIP.",
  "type": "object",
  "required": [
    "manifestVersion",
    "application",
    "oipCompatibility",
    "modules",
    "services",
    "adapters",
    "capabilities",
    "featureFlags",
    "migration"
  ],
  "properties": {
    "manifestVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*))?(?:\\+([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*))?$",
      "description": "Version du Manifest au format SemVer 2.0.0."
    },
    "application": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Identifiant unique et stable de l'application."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Nom lisible de l'application."
        },
        "description": {
          "type": "string",
          "description": "Description fonctionnelle."
        },
        "repository": {
          "type": "string",
          "format": "uri",
          "description": "URL du dépôt de l'application."
        }
      },
      "additionalProperties": false
    },
    "oipCompatibility": {
      "type": "object",
      "required": ["min"],
      "properties": {
        "min": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*))?(?:\\+([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*))?$",
          "description": "Version minimale d'OIP compatible avec ce Manifest."
        },
        "max": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*))?(?:\\+([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*))?$",
          "description": "Version maximale d'OIP testée avec ce Manifest (borne inclusive)."
        },
        "reason": {
          "type": "string",
          "description": "Justification des contraintes de compatibilité."
        }
      },
      "additionalProperties": false
    },
    "modules": {
      "type": "array",
      "description": "Modules métier de l'application.",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Identifiant unique du module."
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*))?(?:\\+([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*))?$"
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "services": {
      "type": "array",
      "description": "Services exposés par l'application.",
      "items": {
        "type": "object",
        "required": ["id", "moduleId", "type", "adapter"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string"
          },
          "moduleId": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "type": {
            "type": "string",
            "enum": ["http", "grpc", "event", "queue", "function"]
          },
          "adapter": {
            "type": "string",
            "description": "Nom de la classe ou fonction adaptatrice OIP."
          },
          "endpoints": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "method"],
              "properties": {
                "path": { "type": "string" },
                "method": {
                  "type": "string",
                  "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
                },
                "purpose": { "type": "string" },
                "aiRelevant": { "type": "boolean", "default": false }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "api": {
      "type": "object",
      "description": "Routes API existantes de l'application.",
      "required": ["basePath", "routes"],
      "properties": {
        "basePath": { "type": "string" },
        "routes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "method"],
            "properties": {
              "path": { "type": "string" },
              "method": {
                "type": "string",
                "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
              },
              "description": { "type": "string" },
              "aiRelevant": { "type": "boolean", "default": false }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "aiEntrypoints": {
      "type": "array",
      "description": "Points d'entrée IA existants.",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "type": {
            "type": "string",
            "enum": ["chat", "voice", "command", "agent", "form"]
          },
          "description": { "type": "string" },
          "channels": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "componentsToReplace": {
      "type": "array",
      "description": "Composants legacy à remplacer par OIP.",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "type": {
            "type": "string",
            "enum": [
              "nlp-parser",
              "intent-router",
              "conversation-engine",
              "decision-tree",
              "rule-engine",
              "workflow-engine",
              "chat-adapter",
              "other"
            ]
          },
          "description": { "type": "string" },
          "migrationPhase": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "capabilities": {
      "type": "array",
      "description": "Capabilities candidates pour OIP.",
      "items": {
        "type": "object",
        "required": ["id", "moduleId", "description", "toolHandler"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9.]+$",
            "description": "Identifiant de capability, par convention domaine.action."
          },
          "moduleId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "description": { "type": "string", "minLength": 1 },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string", "pattern": "^[a-zA-Z0-9_]+$" },
                "type": {
                  "type": "string",
                  "enum": ["string", "number", "boolean", "object", "array"]
                },
                "required": { "type": "boolean", "default": false },
                "description": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "requiredRoles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Tous les rôles listés sont requis (AND)."
          },
          "confirmationLevel": {
            "type": "string",
            "enum": ["none", "low", "medium", "high", "critical"],
            "default": "none"
          },
          "toolHandler": { "type": "string" },
          "emits": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "adapters": {
      "type": "array",
      "description": "Adaptateurs OIP nécessaires pour l'application.",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["identity", "business-tools", "memory", "audit", "events", "knowledge", "document", "ocr", "vector", "llm", "custom"]
          },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "optional": { "type": "boolean", "default": false }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "runtime": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "minVersion": { "type": "string" },
              "purpose": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "purpose": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "external": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "purpose": { "type": "string" },
              "optional": { "type": "boolean", "default": false }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "featureFlags": {
      "type": "array",
      "description": "Feature flags de migration et d'activation.",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "description": { "type": "string" },
          "default": { "type": "boolean", "default": false },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "migration": {
      "type": "object",
      "description": "État et règles de migration vers OIP.",
      "required": ["currentPhase", "phases"],
      "properties": {
        "currentPhase": {
          "type": "string",
          "enum": ["analysis", "manifest", "blueprint", "shadow", "progressive", "cleanup", "complete"]
        },
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": {
                "type": "string",
                "enum": ["analysis", "manifest", "blueprint", "shadow", "progressive", "cleanup", "complete"]
              },
              "name": { "type": "string" },
              "done": { "type": "boolean", "default": false }
            },
            "additionalProperties": false
          },
          "minItems": 1
        },
        "compatibilityRules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["description"],
            "properties": {
              "description": { "type": "string" },
              "condition": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
